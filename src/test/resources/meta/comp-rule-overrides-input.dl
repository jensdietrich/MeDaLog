@[author = "jens"]
.comp Family {
    .decl parent(p: symbol, c: symbol)
    .decl grandparent(gp: symbol, gc: symbol)

    parent("Tim", "Bob").
    parent("Bob", "Ann").

    @[id = "gp-rule"]
    @[author = "alice"]
    grandparent(x, z) :- parent(x, y), parent(y, z).

    .output grandparent
}

.init f = Family
